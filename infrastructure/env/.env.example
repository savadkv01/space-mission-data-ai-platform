# ============================================================================
# Space Mission Data & AI Platform — Environment Template
# Phase 4 Infrastructure Blueprint
#
# USAGE:
#   cp .env.example .env      # then fill in REAL values
#   The .env file is git-ignored and loaded automatically by Docker Compose.
#
# SECURITY: never commit .env. Replace all CHANGE_ME values with strong local
# credentials. See ../../docs/infrastructure/09-security.md
# ============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL (shared backend: metadata, gold, airflow, mlflow, superset, feast)
# ---------------------------------------------------------------------------
POSTGRES_USER=platform
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=platform

# ---------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=platform_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# Kafka (KRaft single broker)
# ---------------------------------------------------------------------------
# Generate a fresh cluster id with: docker run --rm apache/kafka:3.7.0 \
#   /opt/kafka/bin/kafka-storage.sh random-uuid
KAFKA_CLUSTER_ID=5L6g3nShT-eMCtK--X86sw
KAFKA_UI_PORT=8088

# ---------------------------------------------------------------------------
# Spark
# ---------------------------------------------------------------------------
SPARK_MASTER_UI_PORT=8080
SPARK_WORKER_UI_PORT=8081

# ---------------------------------------------------------------------------
# Airflow
# ---------------------------------------------------------------------------
AIRFLOW_PORT=8082

# ---------------------------------------------------------------------------
# MLflow
# ---------------------------------------------------------------------------
MLFLOW_PORT=5000

# ---------------------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------------------
JUPYTER_PORT=8888
JUPYTER_TOKEN=CHANGE_ME_jupyter_token

# ---------------------------------------------------------------------------
# Qdrant (vector database)
# ---------------------------------------------------------------------------
QDRANT_REST_PORT=6333
QDRANT_GRPC_PORT=6334

# ---------------------------------------------------------------------------
# Ollama + Open WebUI (local LLM / RAG)
# ---------------------------------------------------------------------------
OLLAMA_PORT=11434
OPEN_WEBUI_PORT=3000
# Pulled after bootstrap, e.g.: docker exec ollama ollama pull llama3.2:3b
OLLAMA_DEFAULT_MODEL=llama3.2:3b

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318

# ---------------------------------------------------------------------------
# Superset (BI)
# ---------------------------------------------------------------------------
SUPERSET_PORT=8089
SUPERSET_SECRET_KEY=CHANGE_ME_long_random_secret_key
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=CHANGE_ME_superset_password

# ---------------------------------------------------------------------------
# FastAPI (application gateway — implemented in a later phase)
# ---------------------------------------------------------------------------
API_PORT=8000
API_SECRET_KEY=CHANGE_ME_api_secret

# ---------------------------------------------------------------------------
# External dataset API keys (free/public sources — fill if used)
# ---------------------------------------------------------------------------
SPACETRACK_USERNAME=
SPACETRACK_PASSWORD=
NOAA_API_TOKEN=
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=
