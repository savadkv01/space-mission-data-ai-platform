{
  "annotations": { "list": [] },
  "title": "Platform Health",
  "tags": ["space-platform", "infrastructure"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Prometheus Up",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "up{job=\"prometheus\"}", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Scrape Targets Up",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "count(up == 1)", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Target Availability (up)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "targets": [{ "expr": "up", "legendFormat": "{{job}}", "refId": "A" }]
    }
  ]
}
