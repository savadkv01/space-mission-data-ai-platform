# ============================================================================
# Ingestion layer — local env overrides (optional)
#
# The ingestion code primarily reads ../infrastructure/env/.env. Use this file
# only to override endpoints when running connectors/producers from your host
# (outside Docker), e.g. pointing Kafka/MinIO at localhost published ports.
# Copy to .env and adjust. Never commit real secrets.
# ============================================================================

# When running on the host, reach the published container ports:
KAFKA_BOOTSTRAP=localhost:9092
MINIO_ENDPOINT=http://localhost:9000

LOG_LEVEL=INFO
INGESTION_ENV=local

# Dataset credentials are inherited from infrastructure/env/.env:
#   NASA_API_KEY, FIRMS_MAP_KEY, SENTINELHUB_CLIENT_ID/SECRET, GFW_API_TOKEN
