# ============================================================================
# Data Source Pre-flight — Credentials Template
#
# USAGE:
#   cp .env.example .env      # then fill in REAL values (this file stays a template)
#   The .env file is git-ignored and loaded automatically by the preflight tool.
#
# Each block notes whether the source is ANONYMOUS (no creds needed),
# requires a FREE API KEY, or a FREE ACCOUNT + OAUTH token.
# Leave a value blank to SKIP that source's authenticated check.
# ============================================================================

# ---------------------------------------------------------------------------
# NASA api.nasa.gov key (APOD / DONKI / NeoWs)
# Prerequisite: Free API key — https://api.nasa.gov  (DEMO_KEY works, low rate)
# ---------------------------------------------------------------------------
NASA_API_KEY=DEMO_KEY

# ---------------------------------------------------------------------------
# NASA FIRMS active fire (also covers VIIRS) — MAP_KEY
# Prerequisite: Free API key — https://firms.modaps.eosdis.nasa.gov/api/map_key/
# ---------------------------------------------------------------------------
FIRMS_MAP_KEY=

# ---------------------------------------------------------------------------
# Copernicus Data Space Ecosystem (Sentinel-2 / Sentinel-1)
# Prerequisite: Free account — https://dataspace.copernicus.eu
# Option A (recommended): OAuth client credentials
#   Create at https://shapps.dataspace.copernicus.eu/dashboard/ -> User settings
# Option B: account username/password (uses public client "cdse-public")
# Provide EITHER option A OR option B. Catalog browsing works anonymously.
# ---------------------------------------------------------------------------
CDSE_CLIENT_ID=
CDSE_CLIENT_SECRET=
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=

# ---------------------------------------------------------------------------
# Sentinel Hub Process / Statistical API
# Prerequisite: Free account + OAuth client — https://www.sentinel-hub.com
#   Dashboard -> User settings -> OAuth clients
# ---------------------------------------------------------------------------
SENTINELHUB_CLIENT_ID=
SENTINELHUB_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Global Fishing Watch API
# Prerequisite: Free account + API token — https://globalfishingwatch.org/our-apis/
# ---------------------------------------------------------------------------
GFW_API_TOKEN=

# ---------------------------------------------------------------------------
# NASA Earthdata Login (EDL) bearer token — OPTIONAL
# CMR catalog search works anonymously; token only needed for granule downloads.
# Prerequisite: Free account — https://urs.earthdata.nasa.gov  (Generate Token)
# ---------------------------------------------------------------------------
EARTHDATA_TOKEN=

# ---------------------------------------------------------------------------
# NOAA Climate Data Online token — OPTIONAL (supporting source)
# Prerequisite: Free token — https://www.ncdc.noaa.gov/cdo-web/token
# ---------------------------------------------------------------------------
NOAA_API_TOKEN=
